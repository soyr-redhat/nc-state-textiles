apiVersion: v1
kind: Secret
metadata:
  name: librechat-secrets
  namespace: ai-workshop
type: Opaque
stringData:
  # Model API Configuration
  # Replace with your actual endpoint and API key
  OPENAI_API_KEY: "sk-your-api-key-here"
  OPENAI_API_BASE: "https://api.openai.com/v1"

  # MongoDB Connection
  MONGO_URI: "mongodb://mongodb:27017/librechat"

  # LibreChat Security
  # Generate with: openssl rand -base64 32
  JWT_SECRET: "change-me-to-random-string-min-32-chars"
  JWT_REFRESH_SECRET: "change-me-to-another-random-string-min-32-chars"

  # CREDS_KEY for secure credential encryption
  # Generate with: openssl rand -base64 32
  CREDS_KEY: "change-me-to-random-encryption-key"

  # CREDS_IV for credential encryption
  # Generate with: openssl rand -base64 16
  CREDS_IV: "change-me-random-16"

---
# INSTRUCTIONS:
# 1. Copy this file: cp 00-secrets.yaml.template 00-secrets.yaml
# 2. Edit 00-secrets.yaml with your actual values
# 3. Generate random secrets:
#    - JWT_SECRET: openssl rand -base64 32
#    - JWT_REFRESH_SECRET: openssl rand -base64 32
#    - CREDS_KEY: openssl rand -base64 32
#    - CREDS_IV: openssl rand -base64 16
# 4. Add 00-secrets.yaml to .gitignore
# 5. Deploy: oc apply -f 00-secrets.yaml
